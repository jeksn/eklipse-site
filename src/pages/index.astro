---
import Layout from '../layouts/Layout.astro'

const installationSteps = [
	"Download the latest release from Github",
	"Unzip the file",
	"Go to your extensions and enable Developer mode",
	"Click Load Unpacked and select the unzipped folder",
	"Customize the settings to your preferences"
]
---

<Layout title="Eklipse - make youtube work like you want it to">
	<main class="min-h-screen bg-[#0a0a0a] text-white flex flex-col items-center justify-center px-4 py-16">
		<!-- Logo Section -->
		<div class="flex items-center gap-3 mb-4">
			<div class="w-10 h-10 relative">
				<img src="/eklipse.svg" alt="eklipse" class="w-full h-full" />
			</div>
			<h1 class="text-3xl font-normal tracking-tight">Eklipse</h1>
		</div>

		<!-- Tagline -->
		<p class="text-gray-400 text-sm mb-8">Make youtube work like you want it to</p>

		<!-- Buttons -->
		<div class="flex gap-3 mb-12">
			<a
				href="https://github.com/jeksn/eklipse/releases/"
				class="inline-flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-900 text-xs font-medium rounded hover:bg-white transition-colors"
			>
				Download
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
				</svg>
			</a>
			<a
				href="https://github.com/jeksn/eklipse"
				class="inline-flex items-center gap-2 px-4 py-2 bg-gray-800 text-white text-xs font-medium rounded hover:bg-gray-700 transition-colors"
			>
				Github
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
				</svg>
			</a>
		</div>

		<!-- Installation Card -->
		<div class="w-full max-w-sm bg-[#141414] rounded p-6">
			<h2 class="text-sm font-medium mb-4">Installation</h2>
			<ol class="space-y-3 text-xs text-gray-400">
				{installationSteps.map((step, index) => (
					<li class="flex gap-3">
						<span class="text-gray-500">{index + 1}.</span>
						<span>{step}</span>
					</li>
				))}
			</ol>

			<div class="mt-6 pt-6 border-t border-gray-800">
				<h3 class="text-sm font-medium mb-2">Do you have ideas for improvements?</h3>
				<p class="text-xs text-gray-400">
					Create an issue in the repo or send me an e-mail at
					<a href="mailto:hello@jek.sn" class="text-gray-300 underline hover:text-white">hello@jek.sn</a>
				</p>
			</div>
		</div>
	</main>
</Layout>
